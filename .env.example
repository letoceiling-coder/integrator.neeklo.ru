# ─────────────────────────────────────────────────────────────
# NEEKLO Marketplace OS — environment template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173

# PostgreSQL (event store + read models)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=neeklo
POSTGRES_PASSWORD=neeklo
POSTGRES_DB=neeklo
DATABASE_URL=postgresql://neeklo:neeklo@localhost:5432/neeklo?schema=public

# Redis (event bus streams, BullMQ queues, cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# AI — OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_CHAT=openai/gpt-4o-mini
AI_MODEL_ANALYTICS=anthropic/claude-3.7-sonnet
AI_MODEL_LISTING=openai/gpt-4o
AI_MODEL_SUMMARY=google/gemini-2.0-flash
AI_MODEL_IMAGE=black-forest-labs/flux-1.1-pro

# Object storage — Selectel / S3-compatible
S3_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
S3_REGION=ru-1
S3_BUCKET=neeklo-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Marketplace: Avito
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_BASE_URL=https://api.avito.ru

# Integrations
TELEGRAM_BOT_TOKEN=
