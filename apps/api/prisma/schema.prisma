  @@map("marketplace_read_model")
}

// ─────────────────────────────────────────────────────────────
// Metrics & Analytics
// ─────────────────────────────────────────────────────────────

model MetricSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  metricName   String   @map("metric_name")
  value        Float
  dimensions   Json     @default("{}")
  computedAt   DateTime @map("computed_at") @db.Timestamptz(6)

  @@index([tenantId, entityType, entityId, metricName])
  @@index([tenantId, computedAt])
  @@map("metric_snapshot")
}

model RecommendationReadModel {
  id           String   @id @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  kind         String
  confidence   Float
  reason       String
  payload      Json     @default("{}")
  status       String   @default("pending")
  generatedAt  DateTime @map("generated_at") @db.Timestamptz(6)
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@index([tenantId, entityType, entityId, status])
  @@map("recommendation_read_model")
}

model SyncJobReadModel {
  id             String   @id @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  marketplace    String
  mode           String
  status         String
  stats          Json     @default("{}")
  startedAt      DateTime @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  error          String?

  @@index([tenantId, accountId, status])
  @@map("sync_job_read_model")
}

// ─────────────────────────────────────────────────────────────
// Knowledge Graph
// ─────────────────────────────────────────────────────────────

model KnowledgeNode {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  kind       String
  entityId   String   @map("entity_id")
  label      String
  properties Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @map("updated_at") @db.Timestamptz(6)

  edgesFrom KnowledgeEdge[] @relation("from")
  edgesTo   KnowledgeEdge[] @relation("to")

  @@unique([tenantId, kind, entityId])
  @@index([tenantId, kind])
  @@map("knowledge_node")
}

model KnowledgeEdge {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  fromNodeId String   @map("from_node_id") @db.Uuid
  toNodeId   String   @map("to_node_id") @db.Uuid
  relation   String
  weight     Float    @default(1)
  properties Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fromNode KnowledgeNode @relation("from", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   KnowledgeNode @relation("to", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fromNodeId, toNodeId, relation])
  @@index([tenantId, relation])
  @@map("knowledge_edge")
}

// ─────────────────────────────────────────────────────────────
// Observability
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  actorType     String   @map("actor_type")
  actorId       String?  @map("actor_id")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String   @map("resource_id")
  correlationId String   @map("correlation_id")
  details       Json     @default("{}")
  occurredAt    DateTime @map("occurred_at") @db.Timestamptz(6)

  @@index([tenantId, occurredAt])
  @@index([correlationId])
  @@map("audit_log")
}

model TelemetrySpan {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  traceId       String   @map("trace_id")
  spanId        String   @map("span_id")
  parentSpanId  String?  @map("parent_span_id")
  operation     String
  status        String
  durationMs    Int      @map("duration_ms")
  tags          Json     @default("{}")
  startedAt     DateTime @map("started_at") @db.Timestamptz(6)

  @@index([traceId])
  @@index([tenantId, startedAt])
  @@map("telemetry_span")
}

// ─────────────────────────────────────────────────────────────
// Intelligence Layer (Stage 3)
// ─────────────────────────────────────────────────────────────

/// Aggregated historical counters — NOT the event store. Rollups: hour→day→week→month→quarter→year.
model HistoricalAggregate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  granularity  String
  periodStart  DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd    DateTime @map("period_end") @db.Timestamptz(6)
  counters     Json     @default("{}")
  dimensions   Json     @default("{}")
  computedAt   DateTime @map("computed_at") @db.Timestamptz(6)

  @@unique([tenantId, entityType, entityId, granularity, periodStart])
  @@index([tenantId, granularity, periodStart])
  @@index([tenantId, entityType, entityId])
  @@map("historical_aggregate")
}

/// Full metrics vector per entity per time bucket — centralized metrics warehouse.
model MetricsWarehouseRow {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  granularity     String
  periodStart     DateTime @map("period_start") @db.Timestamptz(6)
  ctr             Float    @default(0)
  roi             Float    @default(0)
  roas            Float    @default(0)
  cpa             Float    @default(0)
  cpc             Float    @default(0)
  cpm             Float    @default(0)
  conversion      Float    @default(0)
  engagement      Float    @default(0)
  responseTime    Float    @default(0) @map("response_time")
  cost            Float    @default(0)
  revenue         Float    @default(0)
  averageCheck    Float    @default(0) @map("average_check")
  averageResponse Float    @default(0) @map("average_response")
  averageSaleTime Float    @default(0) @map("average_sale_time")
  mediaScore      Float    @default(0) @map("media_score")
  listingScore    Float    @default(0) @map("listing_score")
  aiScore         Float    @default(0) @map("ai_score")
  regionalScore   Float    @default(0) @map("regional_score")
  competitionScore Float   @default(0) @map("competition_score")
  forecastScore   Float    @default(0) @map("forecast_score")
  opportunityScore Float   @default(0) @map("opportunity_score")
  popularityScore Float    @default(0) @map("popularity_score")
  views           Int      @default(0)
  contacts        Int      @default(0)
  messages        Int      @default(0)
  favorites       Int      @default(0)
  computedAt      DateTime @map("computed_at") @db.Timestamptz(6)

  @@unique([tenantId, entityType, entityId, granularity, periodStart])
  @@index([tenantId, granularity, periodStart])
  @@map("metrics_warehouse_row")
}

model ForecastSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
