// NEEKLO Marketplace OS — data model.
//
// The heart of the system is `event_store`: an append-only, never-deleted log of facts.
// Everything else (`ad_read_model`, analytics, …) is a *projection* rebuildable from it.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

/// Append-only event log. Rows are immutable: no updates, no deletes, ever.
model EventStore {
  /// Global, gap-free ordering for catch-up subscriptions & projections.
  globalPosition BigInt   @id @default(autoincrement()) @map("global_position")
  eventId        String   @unique @map("event_id") @db.Uuid
  aggregateType  String   @map("aggregate_type")
  aggregateId    String   @map("aggregate_id")
  /// Per-stream sequence number; unique with (type,id) → optimistic concurrency.
  streamVersion  Int      @map("stream_version")
  type           String
  tenantId       String   @map("tenant_id")
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id")
  correlationId  String   @map("correlation_id")
  causationId    String?  @map("causation_id")
  occurredAt     DateTime @map("occurred_at") @db.Timestamptz(6)
  recordedAt     DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  payload        Json
  metadata       Json     @default("{}")

  @@unique([aggregateType, aggregateId, streamVersion], name: "stream_position")
  @@index([aggregateType, aggregateId, streamVersion])
  @@index([type])
  @@index([tenantId, occurredAt])
  @@index([correlationId])
  @@map("event_store")
}

/// Tracks how far each projection/consumer has processed the global log.
model ProjectionCheckpoint {
  name      String   @id
  position  BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("projection_checkpoint")
}

// ─────────────────────────────────────────────────────────────
// Identity & access (RBAC)
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  users     User[]

  @@map("tenant")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("manager")
  permissions  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("user")
}

// ─────────────────────────────────────────────────────────────
// OAuth Platform — Credential Vault (Phase A2)
// All secrets stored AES-256-GCM encrypted; never plaintext.
// ─────────────────────────────────────────────────────────────

model OAuthCredentialVault {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  provider          String
  accountId         String    @map("account_id") @db.Uuid
  externalAccountId String?   @map("external_account_id")
  displayName       String    @default("") @map("display_name")
  grantType         String    @default("authorization_code") @map("grant_type")

  clientIdEnc       String    @map("client_id_enc")
  clientSecretEnc   String    @map("client_secret_enc")
  accessTokenEnc    String?   @map("access_token_enc")
  refreshTokenEnc   String?   @map("refresh_token_enc")

  scopes            String[]  @default([])
  tokenExpiresAt    DateTime? @map("token_expires_at") @db.Timestamptz(6)
  refreshExpiresAt  DateTime? @map("refresh_expires_at") @db.Timestamptz(6)

  status            String    @default("pending")
  health            String    @default("unknown")
  lastRefreshAt     DateTime? @map("last_refresh_at") @db.Timestamptz(6)
  lastError         String?   @map("last_error")
  lastSuccessAt     DateTime? @map("last_success_at") @db.Timestamptz(6)
  keyVersion        Int       @default(1) @map("key_version")

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, provider, accountId])
  @@index([tenantId, provider, status])
  @@index([tokenExpiresAt])
  @@map("oauth_credential_vault")
}

model OAuthPendingFlow {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  provider        String
  state           String   @unique
  codeVerifier    String?  @map("code_verifier")
  accountId       String   @map("account_id") @db.Uuid
  clientIdEnc     String   @map("client_id_enc")
  clientSecretEnc String   @map("client_secret_enc")
  scopes          String[] @default([])
  redirectUri     String   @map("redirect_uri")
  userId          String   @map("user_id") @db.Uuid
  expiresAt       DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("oauth_pending_flow")
}

// ─────────────────────────────────────────────────────────────
// Read models (projections) — safe to DROP & rebuild from events
// ─────────────────────────────────────────────────────────────

model AdReadModel {
  id            String   @id @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  marketplace   String
  externalId    String?  @map("external_id")
  status        String
  title         String
  categoryId    String   @map("category_id")
  subcategoryId String?  @map("subcategory_id")
  regionId      String   @map("region_id")
  cityId        String   @map("city_id")
  priceAmount   Int      @map("price_amount")
  priceCurrency String   @default("RUB") @map("price_currency")
  aiScore       Float?   @map("ai_score")

  views         Int   @default(0)
  viewsLast24h  Int   @default(0) @map("views_last_24h")
  favorites     Int   @default(0)
  contacts      Int   @default(0)
  messages      Int   @default(0)
  ctr            Float @default(0)
  conversion     Float @default(0)
  spendAmount    Int   @default(0) @map("spend_amount")
  revenueAmount  Int   @default(0) @map("revenue_amount")
  roi            Float @default(0)
  costPerContact Float @default(0) @map("cost_per_contact")
  costPerView    Float @default(0) @map("cost_per_view")

  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, status])
  @@index([tenantId, marketplace])
  @@index([tenantId, regionId])
  @@map("ad_read_model")
}

// ─────────────────────────────────────────────────────────────
// Event Sourcing — Snapshots
// ─────────────────────────────────────────────────────────────

model AggregateSnapshot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType  String   @map("aggregate_type")
  aggregateId    String   @map("aggregate_id")
  streamVersion  Int      @map("stream_version")
  schemaVersion  Int      @map("schema_version")
  state          Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([aggregateType, aggregateId, streamVersion])
  @@index([aggregateType, aggregateId, streamVersion(sort: Desc)])
  @@map("aggregate_snapshot")
}

